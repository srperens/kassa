# Copy to .env (not auto-loaded – set these in your process manager / shell).
PORT=3000
HOST=0.0.0.0

# Named API keys, comma-separated as name:token pairs. Each person logs in once
# in the app with THEIR token; transactions are attributed to that name, and a
# token can be revoked individually by removing it here. Keep these secret —
# they are the only thing protecting the data on the open internet.
KASSA_TOKENS=per:change-me-secret-1,lena:change-me-secret-2

# Where the SQLite file lives (default: next to the build).
# KASSA_DB=/var/lib/kassa/kassa.sqlite
